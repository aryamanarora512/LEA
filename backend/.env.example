# LEA Sourcing Tool — Environment Variables
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# ── NEWS API (free) ─────────────────────────────────────────────
# Required for: press coverage, notable wins, negative press, lateral news
# Get free key: https://newsapi.org/ → Get API Key
# Tier: Free (100 requests/day), Developer ($449/mo for commercial)
NEWS_API_KEY=your_newsapi_key_here

# ── GOOGLE PLACES API (paid, but $200 free credit/month) ────────
# Required for: Google Stars, review count, firm discovery via Places
# Get key: https://console.cloud.google.com → APIs & Services → Places API
# Cost: ~$17 per 1,000 requests (usually free under $200/mo limit)
GOOGLE_API_KEY=your_google_places_api_key_here

# ── SERP API (freemium) ─────────────────────────────────────────
# Required for: SEO ranking data, enhanced firm discovery
# Get key: https://serpapi.com → Sign up (100 free searches/month)
# Paid: $50/mo for 5,000 searches
SERP_API_KEY=your_serpapi_key_here

# ── SPYFU API (optional) ────────────────────────────────────────
# Required for: ad spend intelligence, competitor PPC data
# Get key: https://www.spyfu.com/api
SPYFU_API_KEY=your_spyfu_key_here

# ─────────────────────────────────────────────────────────────────
# WHAT WORKS WITHOUT ANY API KEYS
# ─────────────────────────────────────────────────────────────────
# ✅ All 8 pre-seeded demo firms with scores
# ✅ CourtListener — federal case dockets & opinions (completely free)
# ✅ SEC EDGAR — M&A filings (completely free)
# ✅ Firm website scraping — attorney count, practice areas, tech stack
# ✅ Avvo scraping — attorney ratings (free scrape)
# ✅ Martindale-Hubbell scraping — AV ratings (free scrape)
# ✅ State bar scraping (free)
# ✅ Full M&A scoring algorithm (all 5 factors)
# ✅ Firm discovery via Avvo + Martindale (free, limited results)
#
# WHAT NEEDS API KEYS
# ─────────────────────────────────────────────────────────────────
# ❌ NEWS_API_KEY — press coverage, wins, negative press, lateral hires
# ❌ GOOGLE_API_KEY — real Google Stars/Reviews, high-quality discovery
# ❌ SERP_API_KEY — SEO rank position, enhanced discovery
# ❌ SPYFU_API_KEY — ad spend intelligence
